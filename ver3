/* === КАРТОЧКА КВАРТИРЫ === */
.listing-card {
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    display: flex;
    cursor: pointer;
}

.listing-card:hover {
    box-shadow: var(--shadow-hover);
}

.listing-gallery {
    width: 240px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    position: relative;
}

.listing-gallery .main-photo {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

.listing-gallery .thumbnails {
    display: flex;
    gap: 4px;
    padding: 8px;
    background: #f5f5f5;
}

.listing-gallery .thumb {
    width: 52px;
    height: 52px;
    object-fit: cover;
    border-radius: 6px;
    cursor: pointer;
    opacity: 0.7;
    transition: all 0.2s;
    border: 2px solid transparent;
}

.listing-gallery .thumb:hover,
.listing-gallery .thumb.active {
    opacity: 1;
    border-color: var(--accent);
}

.listing-gallery .slider-btns {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 8px;
    opacity: 0;
    transition: opacity 0.2s;
}

.listing-card:hover .slider-btns {
    opacity: 1;
}

.listing-gallery .slider-btn {
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}

.listing-info {
    padding: 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.listing-info h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
}

.listing-info .price {
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 4px;
}

.listing-info .price span {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
}

.listing-info .address {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 8px;
}

.listing-info .desc {
    font-size: 13px;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
}

.listing-info .tags {
    display: flex;
    gap: 6px;
    margin-top: 10px;
    flex-wrap: wrap;
}

.listing-info .tag {
    background: var(--border);
    color: var(--text-muted);
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
}

.no-results {
    text-align: center;
    padding: 80px;
    background: var(--bg-card);
    border-radius: 14px;
    color: var(--text-muted);
    font-size: 15px;
}

@media (max-width: 768px) {
    .search-page {
        padding: 20px 0 40px;
    }
    .date-filter {
        flex-direction: column;
        gap: 12px;
    }
    .listing-card {
        flex-direction: column;
    }
    .listing-gallery {
        width: 100%;
    }
    .listing-gallery .main-photo {
        height: 200px;
    }
    .listing-gallery .thumbnails {
        display: none;
    }
    .listing-info {
        padding: 14px 16px;
    }
}

/* === СТРАНИЦА КВАРТИРЫ === */
.card-page {
    padding: 36px 0 60px;
}

.card-page .card-main {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 32px;
    align-items: start;
}

.card-gallery {
    position: relative;
    width: 100%;
    height: 420px;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
}

.card-gallery img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
}

.card-gallery .slider-btns {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 16px;
}

.card-gallery .slider-btn {
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.95);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
    color: #333;
}

.card-gallery .slider-btn:hover {
    background: #fff;
}

.card-details {
    background: var(--bg-card);
    padding: 24px;
    border-radius: 14px;
    box-shadow: var(--shadow);
}

.card-details h1 {
    font-size: 24px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
}

.card-details .address {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 12px;
}

.card-details .price {
    font-size: 32px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 18px;
}

.card-details .price span {
    font-size: 14px;
    font-weight: 400;
    color: var(--text-muted);
}

.card-details h2 {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-top: 20px;
    margin-bottom: 10px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
}

.card-details h2:first-child {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
}

.card-details .description {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.8;
}

.card-details .chars {
    display: flex;
    gap: 10px;
    margin: 12px 0;
    flex-wrap: wrap;
}

.card-details .char {
    background: var(--border);
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
}

.card-details .amenities {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 12px 0;
}

.card-details .amenity {
    background: rgba(10, 76, 30, 0.08);
    color: var(--accent);
    padding: 6px 12px;
    border-radius: 16px;
    font-size: 12px;
    font-weight: 500;
}

.card-actions {
    display: flex;
    gap: 10px;
    margin-top: 18px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
}

.card-actions .btn {
    flex: 1;
    padding: 12px;
}

.card-sidebar {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.card-booking {
    background: var(--bg-card);
    padding: 22px;
    border-radius: 14px;
    box-shadow: var(--shadow);
    height: auto;
}

.card-booking .price {
    font-size: 24px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 14px;
}

.card-booking .price span {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
}

.card-map {
    background: var(--bg-card);
    padding: 16px;
    border-radius: 14px;
    box-shadow: var(--shadow);
}

.card-map h3 {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
}

.card-map img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 8px;
    background: var(--border);
}

.booking-info {
    background: var(--border);
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 12px;
    font-size: 13px;
}

@media (max-width: 1024px) {
    .card-page {
        padding: 20px 0 40px;
    }
    .card-page .container {
        display: block;
        max-width: 100%;
    }
    .card-page .breadcrumbs {
        padding: 0;
        margin-bottom: 24px;
    }
    .card-page .card-main {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .card-page .card-gallery {
        height: 350px;
    }
    .card-page .card-booking {
        position: static;
    }
    .card-page .card-map {
        width: 100%;
    }
}

@media (max-width: 768px) {
    .card-page {
        padding: 16px 0 30px;
    }
    .card-page .card-gallery {
        height: 250px;
        border-radius: 12px;
    }
    .card-page .card-details {
        padding: 16px;
    }
    .card-page .card-details h1 {
        font-size: 20px;
    }
    .card-page .card-details h2 {
        font-size: 16px;
    }
    .card-page .card-details .price {
        font-size: 24px;
    }
    .card-page .card-details .chars {
        gap: 8px;
    }
    .card-page .card-details .char {
        padding: 8px 12px;
        font-size: 12px;
    }
    .card-page .card-details .amenity {
        padding: 4px 10px;
        font-size: 11px;
    }
    .card-page .card-actions {
        flex-direction: column;
    }
    .card-page .card-actions .btn {
        width: 100%;
    }
    .card-page .card-map img {
        height: 180px;
    }
}

/* === МОДАЛКА ФОТО === */
.photo-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    z-index: 2000;
    justify-content: center;
    align-items: center;
}

.photo-modal.active {
    display: flex;
}

.photo-modal-img {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
}

.photo-modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 50px;
    height: 50px;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    border-radius: 50%;
    color: #fff;
    font-size: 30px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.photo-modal-close:hover {
    background: rgba(255, 255, 255, 0.3);
}

.photo-modal-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    border-radius: 50%;
    color: #fff;
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
}

.photo-modal-nav:hover {
    background: rgba(255, 255, 255, 0.3);
}

.photo-modal-prev {
    left: 20px;
}

.photo-modal-next {
    right: 20px;
}

.photo-modal-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: #fff;
    font-size: 16px;
    background: rgba(0, 0, 0, 0.5);
    padding: 8px 16px;
    border-radius: 20px;
}

@media (max-width: 768px) {
    .photo-modal-nav {
        width: 40px;
        height: 40px;
        font-size: 18px;
    }
    .photo-modal-close {
        width: 40px;
        height: 40px;
        font-size: 24px;
    }
    .photo-modal-img {
        max-width: 95%;
        max-height: 85%;
    }
}

/* === ЛИЧНЫЙ КАБИНЕТ === */
.profile-page {
    padding: 40px 0;
}

@media (max-width: 768px) {
    .profile-page {
        padding: 20px 0;
    }
}

.profile-card {
    background: var(--bg-card);
    padding: 36px;
    border-radius: 16px;
    box-shadow: var(--shadow);
    max-width: 800px;
    margin: 0 auto;
}

@media (max-width: 768px) {
    .profile-card {
        padding: 24px;
    }
}

.profile-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 28px;
    border-bottom: 2px solid var(--border);
}

@media (max-width: 480px) {
    .profile-tabs {
        flex-direction: column;
        gap: 0;
    }
}

.profile-tab {
    padding: 12px 24px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    color: var(--text-muted);
    position: relative;
    transition: all 0.2s;
}

.profile-tab:hover {
    color: var(--accent);
}

.profile-tab.active {
    color: var(--accent);
}

.profile-tab.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
}

.profile-tab-content {
    display: none;
}

.profile-tab-content.active {
    display: block;
}

.profile-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
}

@media (max-width: 480px) {
    .profile-header {
        flex-direction: column;
        text-align: center;
    }
}

.profile-avatar {
    width: 72px;
    height: 72px;
    background: var(--accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    font-weight: 700;
    flex-shrink: 0;
}

.profile-info h2 {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
}

.profile-info p {
    font-size: 14px;
    color: var(--text-muted);
}

.profile-section {
    margin-top: 24px;
}

.profile-section h3 {
    font-size: 15px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 14px;
}

.form-group {
    margin-bottom: 14px;
}

.form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 6px;
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 14px;
    border: 2px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    background: var(--bg);
    color: var(--text);
    transition: border-color 0.2s;
}

.form-group input:focus,
.form-group textarea:focus {
    border-color: var(--accent);
    outline: none;
}

.bookings-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.booking-item {
    background: var(--border);
    padding: 16px;
    border-radius: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: all 0.2s;
}

@media (max-width: 480px) {
    .booking-item {
        flex-direction: column;
        align-items: flex-start;
    }
}

.booking-item:hover {
    box-shadow: var(--shadow-hover);
}

.booking-item img {
    width: 80px;
    height: 60px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
}

@media (max-width: 480px) {
    .booking-item img {
        width: 100%;
        height: 120px;
    }
}

.booking-item .info {
    flex: 1;
    min-width: 0;
}

.booking-item .apt-name {
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
}

.booking-item .apt-dates {
    font-size: 13px;
    color: var(--text-muted);
}

.booking-item .right {
    text-align: right;
    flex-shrink: 0;
}

@media (max-width: 480px) {
    .booking-item .right {
        text-align: left;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 12px;
    }
}

.booking-item .status {
    padding: 4px 12px;
    border-radius: 16px;
    font-size: 12px;
    font-weight: 600;
    display: inline-block;
}

.status.pending {
    background: rgba(255, 193, 7, 0.2);
    color: #856404;
}

.status.confirmed {
    background: rgba(40, 167, 69, 0.2);
    color: #155724;
}

.booking-item .price {
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    margin-top: 4px;
}

.empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--bg-card);
    border-radius: 14px;
}

.empty-state p {
    font-size: 16px;
    color: var(--text-muted);
    margin-bottom: 20px;
}
