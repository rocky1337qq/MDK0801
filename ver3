<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ТуТуТ</title>
    <link rel="icon" href="images/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="styles.css?v=2">
</head>
<body>
    <header class="header">
        <div class="container">
            <a href="index.html" class="logo">
                <img src="images/logo.svg" alt="ТуТуТ" class="logo-img logo-img-light">
                <img src="images/logo-dark.svg" alt="ТуТуТ" class="logo-img logo-img-dark">
            </a>
            <nav id="headerNav">
                <a href="index.html" class="active">Главная</a>
                <a href="search.html">Квартиры</a>
                <div id="authButtons"></div>
            </nav>
            <div class="header-right">
                <button class="theme-btn" id="themeBtn" onclick="toggleTheme()">
                    <img src="images/moon.png" alt="Тема" class="theme-icon-moon">
                    <img src="images/sun.png" alt="Тема" class="theme-icon-sun">
                </button>
                <button class="burger" id="burgerBtn" onclick="toggleMenu()">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>
    </header>

    <main>
        <section class="hero">
            <div class="container">
                <div class="hero-content">
                    <h1>Планируйте поездку, начиная с адреса</h1>
                    <p>Проверенные квартиры и апартаменты в Оренбурге — уютное жильё для вашего комфортного пребывания</p>
                </div>
                <div class="hero-image">
                    <img src="images/tusovka.jpg" alt="Оренбург">
                </div>
            </div>
        </section>

        <section class="search-section">
            <div class="container">
                <div class="search-card">
                    <form class="search-form" id="searchForm">
                        <div>
                            <label>Город</label>
                            <select id="citySelect">
                                <option value="Оренбург">Оренбург</option>
                            </select>
                        </div>
                        <div>
                            <label>Заезд</label>
                            <select id="checkinSelect">
                                <option value="">Выберите дату</option>
                            </select>
                        </div>
                        <div>
                            <label>Выезд</label>
                            <select id="checkoutSelect">
                                <option value="">Выберите дату</option>
                            </select>
                        </div>
                        <button type="submit" class="btn">Найти</button>
                    </form>
                </div>
            </div>
        </section>

        <section class="features">
            <div class="features-container">
                <h2 class="features-title">Что мы предлагаем?</h2>
                <div class="features-inner">
                    <div class="feature-card card-1">
                        <img src="images/ptichka.svg" alt="" class="feature-icon">
                        <h3>Пространство,</h3>
                        <p>где только вы и город</p>
                    </div>
                    <div class="feature-card card-2">
                        <h3>Полноценные квартиры <br> c кухней и микроволновкой</h3>
                        <p>Никаких гостиничных коридоров и чужих глаз.</p>
                    </div>
                    <div class="feature-card card-3">
                        <img src="images/Design.svg" alt="" class="feature-icon">
                        <h3>Дизайн</h3>
                        <p>с местным характером</p>
                    </div>
                    <div class="feature-card card-4">
                        <h3>Апартаменты, которые отражают дух района.</h3>
                        <p>От сталинского ампира до лофтов с панорамными окнами.</p>
                    </div>
                    <div class="feature-card card-5">
                        <img src="images/Apartment.svg" alt="" class="feature-icon">
                        <h3>Бронирование</h3>
                        <p>без ожидания и сюрпризов</p>
                    </div>
                    <div class="feature-card card-6">
                        <h3>Фото соответствуют реальности</h3>
                        <p>А заезд происходит онлайн или по коду. 200 000 вариантов с честными отзывами.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="steps">
            <div class="container">
                <h2 class="section-title">Как всё пройдёт</h2>
                <div class="steps-grid">
                    <div class="step-card">
                        <h3>Выбирайте и влюбляйтесь</h3>
                        <p>10 вариантов с реальными фотографиями и отметками на карте. Фильтры помогут найти тот самый балкон с видом.</p>
                        <span class="step-number">1</span>
                    </div>
                    <div class="step-card">
                        <h3>Проверяйте</h3>
                        <p>Самостоятельно выбирайте квартиру по фотографиям, цене и отзывам. Никаких скрытых платежей.</p>
                        <span class="step-number">2</span>
                    </div>
                    <div class="step-card">
                        <h3>Заезд</h3>
                        <p>Код из приложения или ключ в ячейке. В любое время, даже если поезд прибудет поздно ночью.</p>
                        <span class="step-number">3</span>
                    </div>
                    <div class="step-card">
                        <h3>Несколько кликов — адрес ваш</h3>
                        <p>Мгновенное подтверждение, без звонков и ожидания. Вся переписка с хозяином остаётся в чате приложения.</p>
                        <span class="step-number">4</span>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <p>2016-2026 ТуТуТ — Сервис аренды квартир на сутки</p>
            <a href="#">Пользовательское соглашение</a>
        </div>
    </footer>

    <!-- Модалка входа -->
    <div class="modal" id="loginModal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModal('loginModal')">x</button>
            <h2>Вход в аккаунт</h2>
            <form id="loginForm">
                <div class="form-group">
                    <label>Email или телефон</label>
                    <input type="text" id="loginEmail" placeholder="example@mail.ru" required maxlength="100">
                </div>
                <div class="form-group">
                    <label>Пароль</label>
                    <input type="password" id="loginPassword" placeholder="Введите пароль" required maxlength="50">
                </div>
                <button type="submit" class="btn">Войти</button>
            </form>
            <div class="modal-footer">
                Нет аккаунта? 
                <a href="#" onclick="event.preventDefault(); closeModal('loginModal'); openModal('registerModal')">
                    Зарегистрироваться
                </a>
            </div>
        </div>
    </div>

    <!-- Модалка регистрации -->
    <div class="modal" id="registerModal">
        <div class="modal-content">
            <button class="modal-close" onclick="closeModal('registerModal')">x</button>
            <h2>Регистрация</h2>
            <form id="registerForm">
                <div class="form-group">
                    <label>Ваше имя</label>
                    <input type="text" id="regName" placeholder="Иван" required maxlength="50">
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="regEmail" placeholder="example@mail.ru" required maxlength="100">
                </div>
                <div class="form-group">
                    <label>Пароль</label>
                    <input type="password" id="regPassword" placeholder="Минимум 6 символов" required minlength="6" maxlength="50">
                </div>
                <button type="submit" class="btn">Зарегистрироваться</button>
            </form>
            <div class="modal-footer">
                Уже есть аккаунт? 
                <a href="#" onclick="event.preventDefault(); closeModal('registerModal'); openModal('loginModal')">
                    Войти
                </a>
            </div>
        </div>
    </div>

    <script>
        // Инициализация темы
        function initTheme() {
            var t = localStorage.getItem('theme');
            if (t === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else if (t === 'light') {
                document.documentElement.removeAttribute('data-theme');
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        }

        // Переключение темы
        function toggleTheme() {
            if (document.documentElement.hasAttribute('data-theme')) {
                document.documentElement.removeAttribute('data-theme');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            }
        }

        // Переключение меню
        function toggleMenu() {
            document.getElementById('headerNav').classList.toggle('open');
            document.getElementById('burgerBtn').classList.toggle('open');
        }

        // Проверка авторизации
        function checkAuth() {
            var user = localStorage.getItem('user');
            var authDiv = document.getElementById('authButtons');
            
            if (user) {
                user = JSON.parse(user);
                var fl = user.name ? user.name.charAt(0).toUpperCase() : user.email.charAt(0).toUpperCase();
                var sn = user.name ? user.name.split(' ')[0] : user.email.split('@')[0];
                authDiv.innerHTML = 
                    '<div class="user-menu">' +
                        '<button class="user-btn" onclick="toggleUserMenu()">' +
                            '<span class="avatar">' + fl + '</span>' +
                            sn +
                        '</button>' +
                        '<div class="user-dropdown" id="userDropdown">' +
                            '<a href="profile.html">Личный кабинет</a>' +
                            '<a href="#" class="logout" onclick="logout()">Выйти</a>' +
                        '</div>' +
                    '</div>';
            } else {
                authDiv.innerHTML = '<button class="btn" onclick="openModal(\'loginModal\')">Вход</button>';
            }
        }

        function toggleUserMenu() {
            document.getElementById('userDropdown').classList.toggle('active');
        }

        document.addEventListener('click', function(e) {
            var d = document.getElementById('userDropdown');
            var b = document.querySelector('.user-btn');
            if (d && b && !b.contains(e.target) && !d.contains(e.target)) {
                d.classList.remove('active');
            }
        });

        function openModal(id) { 
            document.getElementById(id).classList.add('active'); 
        }
        
        function closeModal(id) { 
            document.getElementById(id).classList.remove('active'); 
        }

        document.querySelectorAll('.modal').forEach(function(m) {
            m.addEventListener('click', function(e) {
                if (e.target === m) m.classList.remove('active');
            });
        });

        document.getElementById('loginForm').onsubmit = function(e) {
            e.preventDefault();
            var email = document.getElementById('loginEmail').value.trim();
            var user = { email: email, name: email.split('@')[0] };
            localStorage.setItem('user', JSON.stringify(user));
            closeModal('loginModal');
            checkAuth();
            this.reset();
        };

        document.getElementById('registerForm').onsubmit = function(e) {
            e.preventDefault();
            var name = document.getElementById('regName').value.trim();
            var email = document.getElementById('regEmail').value.trim();
            var user = { email: email, name: name };
            localStorage.setItem('user', JSON.stringify(user));
            closeModal('registerModal');
            checkAuth();
            this.reset();
            alert('Регистрация прошла успешно!');
        };

        function logout() {
            localStorage.removeItem('user');
            checkAuth();
        }

        // Заполнение дат
        var months = ['Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь', 
                     'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь'];
        var daysInMonth = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
        
        for (var m = 0; m < 12; m++) {
            for (var d = 1; d <= daysInMonth[m]; d++) {
                var date = '2026-' + String(m + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
                var label = d + ' ' + months[m] + ' 2026';
                
                var opt1 = document.createElement('option');
                opt1.value = date;
                opt1.text = label;
                checkinSelect.appendChild(opt1);
                
                var opt2 = document.createElement('option');
                opt2.value = date;
                opt2.text = label;
                checkoutSelect.appendChild(opt2);
            }
        }

        document.getElementById('searchForm').onsubmit = function(e) {
            e.preventDefault();
            var city = document.getElementById('citySelect').value;
            var checkin = checkinSelect.value;
            var checkout = checkoutSelect.value;
            
            var url = 'search.html?city=' + encodeURIComponent(city);
            if (checkin) url += '&checkin=' + checkin;
            if (checkout) url += '&checkout=' + checkout;
            
            window.location.href = url;
        };

        initTheme();
        checkAuth();
    </script>
</body>
</html>

